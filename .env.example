# Copy this file to .env.local for local development.
# Set the same variables in Vercel Project Settings for production.
# Never commit real CDP or Blob credentials.

X402_PAY_TO=0xYourReceivingWallet
CDP_API_KEY_ID=your-cdp-key-id
CDP_API_KEY_SECRET=your-cdp-key-secret
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_your-token

# Mixpanel browser analytics. The project token is intentionally public.
NEXT_PUBLIC_MIXPANEL_TOKEN=your-mixpanel-project-token
NEXT_PUBLIC_MIXPANEL_API_HOST=https://api-eu.mixpanel.com
NEXT_PUBLIC_MIXPANEL_DEBUG=false
